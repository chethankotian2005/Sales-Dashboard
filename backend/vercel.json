{
  "version": 2,
  "buildCommand": "bash build.sh",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings"
  }
}